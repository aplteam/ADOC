    ‚ąá vs‚ÜźCreateBody(vs chapterNo);tail;type;name;flag;title
      tail‚Üźvs.devisor{0=‚ČĘ‚ćļ:‚ćĶ ‚čĄ ' &lt; ',‚ćļ},{‚ćĶ/‚ć®‚ćĶ‚ČĘ' (Container)'}' (',vs.scriptType,')'
      _WithRunningNumbers‚Üź{¬Į1=‚ćĶ:1<‚ČĘ_META ‚čĄ ‚ćĶ}_WithRunningNumbers
      :If 0=‚ČĘvs.subTitle
          title‚Üźvs.formattedScriptName
      :Else
          title‚Üźvs.subTitle
      :EndIf
      :If _WithRunningNumbers
          :If vs.isContainer
              name‚Üź('. ',‚ć®‚ćēvs.subHeadingCounter),title
              vs.subHeadingCounter+‚Üź1
              vs.containerCounter‚Üź1
          :ElseIf vs.hasContainers
              name‚Üź((‚ćēvs.subHeadingCounter-1),'.',(‚ćēvs.containerCounter),' '),title
              vs.containerCounter+‚Üź1
          :Else
              name‚Üź('. ',‚ć®‚ćēchapterNo),title
          :EndIf
      :Else
