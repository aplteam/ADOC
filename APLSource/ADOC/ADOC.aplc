              head‚Üź''
              head,‚Üź'<meta http-equiv="Content-Type" content="text/html;charset=utf-8"/>',nl
              :If 2=‚éēNC'Title'
                  :If 0=‚ČĘTitle
                      head,‚Üź'title'tag 1‚äÉ1‚äÉ_META
                  :Else
                      head,‚Üź'title'tag Title
                  :EndIf
              :Else
                  head,‚Üź'title'tag{1=‚ČĘ‚ćĶ:'ADOC: ',1 1‚äÉ‚ćĶ ‚čĄ 'ADOC: ',(‚ćē‚ČĘ‚ćĶ),' scripts'}_META
              :EndIf
              :If 0‚Č†‚ČĘpath‚Üź_CssPath
                  path,‚Üź'/'/‚ć®~(¬Į1‚ÜĎpath)‚ąä'/\'
                  ((path='\')/path)‚Üź'/'
              :EndIf
              addExt‚Üź{'.css'‚Č°¬Į4‚ÜĎ‚éēC ‚ćĶ:‚ćĶ ‚čĄ ‚ćĶ,'.css'}
              :If _IncludeCss
                  :If 0=‚ČĘpath
                      screenStyles‚Üź'style type="text/css" media="screen"'tag(‚ČĘnl)‚Üď‚ąänl‚ąė,¬®GetScreenCss
                      printStyles‚Üź'style type="text/css" media="print"'tag(‚ČĘnl)‚Üď‚ąänl‚ąė,¬®GetPrintCss
                  :Else
                      :Trap 22
                          screenStyles‚Üź'style type="text/css" media="screen"'tag(‚ČĘnl)‚Üď‚ąänl‚ąė,¬®ReadAnsiFile path,addExt CssScreen
                      :Else
                          screenStyles‚Üź'style type="text/css" media="screen"'tag(‚ČĘnl)‚Üď‚ąänl‚ąė,¬®GetScreenCss
                      :EndTrap
                      :Trap 22
                          printStyles‚Üź'style type="text/css" media="print"'tag(‚ČĘnl)‚Üď‚ąänl‚ąė,¬®ReadAnsiFile path,addExt CssPrint
                      :Else
                          printStyles‚Üź'style type="text/css" media="print"'tag(‚ČĘnl)‚Üď‚ąänl‚ąė,¬®GetPrintCss
                      :EndTrap
                  :EndIf
                  head,‚ÜźscreenStyles,printStyles
              :Else
                  fn‚Üź({‚ćĶ‚Üď‚ć®1+-‚Ćä/'\/'‚ć≥‚ć®‚ĆĹ‚ćĶ}GetTempFileName),addExt CssScreen
                  head,‚Üź'<link rel="stylesheet" type="text/css" charset="utf-8" media="all" href="file:///',path,fn,'" />',nl
                  fn‚Üź({‚ćĶ‚Üď‚ć®1+-‚Ćä/'\/'‚ć≥‚ć®‚ĆĹ‚ćĶ}GetTempFileName),addExt CssPrint
                  head,‚Üź'<link rel="stylesheet" type="text/css" charset="utf-8" media="print" href="file:///',path,fn,'" />',nl
              :EndIf
              head‚Üź'head'tag head
              html‚Üź'html xmlns="http://www.w3.org/1999/xhtml"'tag head,html
              html,‚ć®‚Üź'<?xml version="1.0" encoding="utf-8"?>',nl,'<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">',nl
              _HTML‚Üźhtml
